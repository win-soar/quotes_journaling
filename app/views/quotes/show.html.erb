<div class="quote-detail-header quote-category--<%= @quote.category.downcase.gsub(' ', '-') %>">
  <h2>"<%= @quote.title %>"</h2>
</div>

<div class="quote-meta">
  <%= avatar_image_tag(@quote.user, size: "52x52") %>
  <span class="quote-meta-name"><%= link_to @quote.user.name, user_path(@quote.user) %></span>

  <div class="quote-meta-actions">
    <% if @quote.user == current_user %>
      <%= link_to '編集', edit_quote_path(@quote), class: 'btn btn-sm btn-outline-light' %>
      <%= button_to '削除', quote_path(@quote), method: :delete,
            data: { confirm: 'このクォーツを削除しますか？' },
            class: 'btn btn-sm btn-outline-danger' %>
    <% else %>
      <%= link_to '通報', new_quote_report_path(@quote), class: 'btn btn-sm btn-outline-warning' %>
    <% end %>
  </div>
</div>

<div class="quote-info">
  <div class="info-row">
    <span class="info-label">発言者</span>
    <span><%= @quote.author %></span>
  </div>
  <div class="info-row">
    <span class="info-label">カテゴリ</span>
    <span><%= @quote.category.humanize %></span>
  </div>
  <% if @quote.source.present? %>
    <div class="info-row">
      <span class="info-label">出典</span>
      <span><%= @quote.source %><% if @quote.source_writer.present? %>（<%= @quote.source_writer %>）<% end %></span>
    </div>
  <% end %>
  <div class="info-row" style="flex-direction: column;">
    <span class="info-label">紹介</span>
    <div class="note-content"><%= simple_format(@quote.note) %></div>
  </div>
</div>

<div class="section-divider"></div>

<%= render @comments %>

<% if @comment.errors.any? %>
  <div class="alert flash-message">
    <ul>
      <% @comment.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="comment-form">
  <div>
    <%= avatar_image_tag(current_user, size: "40x40") %>
  </div>

  <%= form_with(model: [@quote, @comment], local: true) do |form| %>
    <div style="flex: 1;">
      <%= form.text_area :body, rows: 3, class: "form-control", placeholder: 'コメントを入力' %>
      <div class="mt-2">
        <%= form.submit 'コメントする', class: "btn btn-primary btn-sm" %>
      </div>
    </div>
  <% end %>
</div>

<div class="return-button">
  <%= link_to "← 戻る", quotes_path, class: "btn btn-outline-light btn-sm" %>
</div>
