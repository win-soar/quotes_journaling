<header class="header">
  <h1 class="logo<%= ' logo--circle' if circle_mode? %>">
    <%= link_to 'Quotes Journaling', circle_mode? ? circle_quotes_path(current_circle) : root_path %>
  </h1>

  <% if circle_mode? %>
    <div class="circle-info-center">
      <%= link_to circle_members_path(current_circle) do %>
        <strong class="circle-name"><%= current_circle.name %></strong>
        <span class="circle-member-count">メンバー <%= current_circle.member_count %>人</span>
      <% end %>
    </div>
  <% end %>

  <% if user_signed_in? %>
    <div class="header-menu">
      <% unless circle_mode? %>
        <%= link_to guide_path do %>
          <%= image_tag("question.png", alt: "ガイド", class: "search-icon") %>
        <% end %>
        <%= link_to search_quotes_path do %>
          <%= image_tag("search.png", alt: "検索", class: "search-icon") %>
        <% end %>
        <%= link_to '週間ランキング', weekly_likes_rankings_path %>
        <%= link_to '通算ランキング', total_likes_rankings_path %>
      <% end %>
      <%= link_to user_path(current_user) do %>
        <%= avatar_image_tag(current_user, size: "50x50") %>
      <% end %>
    </div>
  <% end %>
</header>
