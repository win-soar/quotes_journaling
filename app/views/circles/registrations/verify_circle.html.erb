<div class="circle-auth-container">
  <h2>サークルパスワードを入力</h2>

  <p style="text-align: center; font-size: 0.9rem; opacity: 0.75; margin-bottom: 20px; font-family: 'Noto Sans JP', sans-serif;">
    Googleアカウントの認証が完了しました。<br>
    <%= @circle.name %> に参加するにはサークルパスワードが必要です。
  </p>

  <% if flash[:alert] %>
    <div style="background: rgba(200,0,0,0.2); border-left: 3px solid #f8192b; border-radius: 6px; padding: 10px 14px; margin-bottom: 16px; font-size: 0.9rem; font-family: 'Noto Sans JP', sans-serif;">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: circle_join__verify_circle_path(join_token: @circle.join_token), method: :post, local: true do |f| %>
    <div class="form-group">
      <%= label_tag :circle_password, 'サークルパスワード *' %>
      <%= password_field_tag :circle_password, nil, class: "form-control" %>
    </div>

    <%= f.submit '参加する', class: "btn btn-primary" %>
  <% end %>
</div>
