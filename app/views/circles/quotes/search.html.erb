<h2>クォーツを検索</h2>

<%= form_with url: search_result_circle_quotes_path(current_circle), method: :get, local: true do |f| %>
  <div>
    <%= f.label :title, 'タイトル' %><br>
    <%= f.text_field :title, class: "form-control" %>
  </div><br>

  <div>
    <%= f.label :author, '発言者' %><br>
    <%= f.text_field :author, class: "form-control" %>
  </div><br>

  <div>
    <%= f.label :note, '紹介内容' %><br>
    <%= f.text_field :note, class: "form-control" %>
  </div><br>

  <div>
    <%= f.label :source, '出典' %><br>
    <%= f.text_field :source, class: "form-control" %>
  </div><br>

  <div>
    <%= f.submit '検索', class: "btn btn-primary" %>
  </div>
<% end %>
